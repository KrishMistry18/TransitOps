# TransitOps unified backend (Prisma + MongoDB)
# MongoDB transactions require a replica set — MongoDB Atlas satisfies this automatically.
# For a local single-node replica set, start mongod with --replSet rs0 and run rs.initiate().
MONGODB_URI="mongodb://localhost:27017/transitops?replicaSet=rs0"

# JWT signing secret — override in production.
JWT_SECRET="supersecretjwtkey123"

PORT=5000
