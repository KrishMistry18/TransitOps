// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  passwordHash        String
  name                String
  role                Role
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

model Vehicle {
  id                 Int       @id @default(autoincrement())
  registrationNumber String    @unique
  name               String
  type               String
  maxLoadCapacity    Float
  odometer           Float     @default(0)
  acquisitionCost    Float
  status             VehicleStatus @default(AVAILABLE)
  region             String

  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  expenses           Expense[]
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

model Driver {
  id                 Int       @id @default(autoincrement())
  name               String
  licenseNumber      String    @unique
  licenseCategory    String
  licenseExpiryDate  DateTime
  contactNumber      String
  safetyScore        Float     @default(100)
  status             DriverStatus @default(AVAILABLE)

  trips              Trip[]
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model Trip {
  id              Int       @id @default(autoincrement())
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance Float
  actualDistance  Float?
  fuelConsumed    Float?
  revenue         Float?
  status          TripStatus @default(DRAFT)
  dispatchedAt    DateTime?
  completedAt     DateTime?

  vehicleId       Int
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId        Int
  driver          Driver    @relation(fields: [driverId], references: [id])
  
  fuelLogs        FuelLog[]
}

enum MaintenanceStatus {
  ACTIVE
  CLOSED
}

model MaintenanceLog {
  id          Int       @id @default(autoincrement())
  description String
  cost        Float?
  status      MaintenanceStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime?

  vehicleId   Int
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        Int       @id @default(autoincrement())
  liters    Float
  cost      Float
  date      DateTime

  vehicleId Int
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  tripId    Int?
  trip      Trip?     @relation(fields: [tripId], references: [id])
}

enum ExpenseType {
  TOLL
  MAINTENANCE
  OTHER
}

model Expense {
  id          Int       @id @default(autoincrement())
  type        ExpenseType
  amount      Float
  description String?
  date        DateTime

  vehicleId   Int
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
}

model DepotSettings {
  id           Int       @id @default(autoincrement())
  depotName    String
  currency     String    @default("USD")
  distanceUnit String    @default("km")
}
